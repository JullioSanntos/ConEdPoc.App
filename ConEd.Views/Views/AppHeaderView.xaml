<?xml version="1.0" encoding="utf-8"?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ConEd.Views.Views.AppHeaderView">

    <Grid ColumnDefinitions="*, Auto" Padding="20,0,20,20" BackgroundColor="#0072C6">

        <Image Grid.Column="0" 
               Source="conedison_logo.png" 
               HeightRequest="24" 
               HorizontalOptions="Start" 
               VerticalOptions="Center" />

        <HorizontalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
            <Label Text="123 Main St..." 
                   TextColor="White" 
                   FontSize="16" 
                   FontAttributes="Bold" 
                   VerticalOptions="Center" />
            <Label Text="▼" 
                   TextColor="White" 
                   FontSize="12" 
                   Margin="0,2,0,0"
                   VerticalOptions="Center" />
        </HorizontalStackLayout>

    </Grid>
</ContentView>