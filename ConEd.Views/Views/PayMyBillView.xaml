<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ConEd3.ViewModels;assembly=ConEd3.ViewModels"
             x:Class="ConEd.Views.Views.PayMyBillView"
             x:DataType="vm:PayMyBillViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F0F4F8">

    <Grid RowDefinitions="Auto, *">

        <!-- The Horizontal Scrollable Tab Bar -->
        <ScrollView Grid.Row="0" Orientation="Horizontal" BackgroundColor="#0072C6" HorizontalScrollBarVisibility="Never">
            <HorizontalStackLayout Padding="20,20,20,0" Spacing="30">

                <!-- Tab 1 -->
                <VerticalStackLayout>
                    <Label Text="CURRENT BILL" TextColor="White" FontAttributes="Bold" FontSize="14" Margin="0,0,0,10"/>
                    <BoxView HeightRequest="4" Color="White" CornerRadius="2" />
                    <!-- Active Indicator -->
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SwitchTabCommand}" CommandParameter="Current" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <!-- Tab 2 -->
                <VerticalStackLayout>
                    <Label Text="BILL HISTORY" TextColor="#B3D4F0" FontSize="14" Margin="0,0,0,10"/>
                    <BoxView HeightRequest="4" Color="Transparent" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SwitchTabCommand}" CommandParameter="History" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <!-- Tab 3 -->
                <VerticalStackLayout>
                    <Label Text="PAYMENT" TextColor="#B3D4F0" FontSize="14" Margin="0,0,0,10"/>
                    <BoxView HeightRequest="4" Color="Transparent" />
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SwitchTabCommand}" CommandParameter="Pay" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

            </HorizontalStackLayout>
        </ScrollView>

        <!-- Placeholder for the dynamic content -->
        <Label Grid.Row="1" Text="Content swaps here..." HorizontalOptions="Center" VerticalOptions="Center" TextColor="Gray" />

    </Grid>
</ContentPage>