<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ConEd3.ViewModels;assembly=ConEd3.ViewModels"
             xmlns:views="using:ConEd.Views.Views"
             x:Class="ConEd.Views.Views.ManageMenuView"
             x:DataType="vm:ManageMenuViewModel"
             Shell.NavBarIsVisible="False"
             BindingContext="{Binding Source={StaticResource MainVM}, Path=ManageMenuViewModel}"
             BackgroundColor="#F0F4F8">

    <ScrollView>
        <VerticalStackLayout>

            <VerticalStackLayout BackgroundColor="#0072C6" Padding="0,20,0,30" Spacing="15">

                <views:AppHeaderView Margin="0,0,0,10" />

                <VerticalStackLayout HorizontalOptions="Center" Spacing="5">
                    <Label Text="Your account number is:" TextColor="White" FontSize="15" FontAttributes="Bold" HorizontalOptions="Center" />

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                        <Label Text="{Binding DisplayAccountNumber}" TextColor="White" FontSize="24" FontAttributes="Bold" VerticalOptions="Center" />

                        <ImageButton Source="eye.ico" 
                                     Command="{Binding ToggleAccountVisibilityCommand}" 
                                     WidthRequest="26" HeightRequest="26" 
                                     VerticalOptions="Center" BackgroundColor="Transparent" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout HorizontalOptions="Center" Margin="0,10,0,15">
                    <Label Text="{Binding ServiceAddressLine1}" TextColor="White" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center" />
                    <Label Text="{Binding ServiceAddressLine2}" TextColor="White" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center" />
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Padding="20,0">
                    <Button Grid.Column="0" Text="Stop Service" Command="{Binding StopServiceCommand}"
                            BackgroundColor="White" TextColor="#0072C6" FontSize="16" FontAttributes="Bold" CornerRadius="4" Padding="0,12" />

                    <Button Grid.Column="1" Text="Move Service" Command="{Binding MoveServiceCommand}"
                            BackgroundColor="White" TextColor="#0072C6" FontSize="16" FontAttributes="Bold" CornerRadius="4" Padding="0,12" />
                </Grid>

            </VerticalStackLayout>

            <VerticalStackLayout Padding="20,20,20,40" Spacing="20">

                <Border BackgroundColor="White" StrokeThickness="0" Padding="20,30">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.05" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">

                        <Label Text="{Binding AmountDue, StringFormat='${0:F2}'}" TextColor="#000000" FontSize="34" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Label Text="{Binding DueDate, StringFormat='Due {0}'}" TextColor="#333333" FontSize="15" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,0,0,15" />

                        <Button Text="Pay Bill" Command="{Binding PayBillCommand}"
                                BackgroundColor="#0072C6" TextColor="White" FontSize="16" FontAttributes="Bold" CornerRadius="4" WidthRequest="260" HeightRequest="48" Padding="0" />

                        <Label Text="REQUEST EXTENSION" 
                               TextColor="#0072C6" 
                               FontSize="14" 
                               FontAttributes="Bold" 
                               TextDecorations="Underline" 
                               HorizontalOptions="Center" 
                               Margin="0,10,0,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding RequestExtensionCommand}" />
                            </Label.GestureRecognizers>
                        </Label>

                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White" StrokeThickness="0" Padding="20,30">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.05" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="Next Meter Reading" TextColor="#000000" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Label Text="Data loading..." TextColor="#555555" FontSize="15" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>