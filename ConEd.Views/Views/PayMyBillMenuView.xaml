<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ConEd3.ViewModels;assembly=ConEd3.ViewModels"
             xmlns:controls="using:ConEd.Views.Controls"
             xmlns:attached="using:ConEd.Views.Controls.AttachedProperties"
             x:Class="ConEd.Views.Views.PayMyBillMenuView"
             x:DataType="vm:PayMyBillMenuViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F0F4F8">

    <Grid RowDefinitions="Auto, *">

        <ScrollView Grid.Row="0" Orientation="Horizontal" BackgroundColor="#0072C6" HorizontalScrollBarVisibility="Never">
            <HorizontalStackLayout Padding="20,20,20,0" Spacing="20">

                <controls:TabItem Title="CURRENT BILL"
                                  Command="{Binding SwitchTabCommand}"
                                  CommandParameter="{x:Static vm:PayMyBillMenuViewModel.CurrentBillRoute}"
                                  IsActive="{Binding IsCurrentBillActive}" />

                <controls:TabItem Title="BILL HISTORY"
                                  Command="{Binding SwitchTabCommand}"
                                  CommandParameter="{x:Static vm:PayMyBillMenuViewModel.BillHistoryRoute}"
                                  IsActive="{Binding IsBillHistoryActive}" />

                <controls:TabItem Title="PAYMENT"
                                  Command="{Binding SwitchTabCommand}"
                                  CommandParameter="{x:Static vm:PayMyBillMenuViewModel.PayBillRoute}"
                                  IsActive="{Binding IsPayBillActive}" />

            </HorizontalStackLayout>
        </ScrollView>

        <ContentView Grid.Row="1" attached:RegionManager.ViewModel="{Binding ActiveViewModel}" />

    </Grid>
</ContentPage>