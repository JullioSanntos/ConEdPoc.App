<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ConEd3.ViewModels;assembly=ConEd3.ViewModels"
             xmlns:attached="using:ConEd.Views.Controls.AttachedProperties"
             x:Class="ConEd.Views.Views.PayMyBillMenuView"
             x:DataType="vm:PayMyBillMenuViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F0F4F8">

    <Grid RowDefinitions="Auto, *">

        <ScrollView Grid.Row="0" Orientation="Horizontal" BackgroundColor="#0072C6" HorizontalScrollBarVisibility="Never">
            <HorizontalStackLayout Padding="20,20,20,0" Spacing="30">

                <VerticalStackLayout>
                    <Label Text="CURRENT BILL" TextColor="White" FontAttributes="Bold" FontSize="14" Margin="0,0,0,10"/>
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SwitchTabCommand}" CommandParameter="{x:Static vm:PayMyBillMenuViewModel.CurrentBillRoute}" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <VerticalStackLayout>
                    <Label Text="BILL HISTORY" TextColor="#B3D4F0" FontSize="14" Margin="0,0,0,10"/>
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SwitchTabCommand}" CommandParameter="{x:Static vm:PayMyBillMenuViewModel.BillHistoryRoute}" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <VerticalStackLayout>
                    <Label Text="PAYMENT" TextColor="#B3D4F0" FontSize="14" Margin="0,0,0,10"/>
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SwitchTabCommand}" CommandParameter="{x:Static vm:PayMyBillMenuViewModel.PayBillRoute}" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

            </HorizontalStackLayout>
        </ScrollView>

        <ContentView Grid.Row="1" attached:RegionManager.ViewModel="{Binding ActiveViewModel}" />

    </Grid>
</ContentPage>