<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ConEd3.ViewModels.PayMyBillViewModels;assembly=ConEd3.ViewModels"
             x:Class="ConEd.Views.Views.PayMyBillViews.CurrentBillView"
             x:DataType="vm:CurrentBillViewModel">

    <Grid RowDefinitions="Auto, *" BackgroundColor="#F0F4F8">

        <VerticalStackLayout Grid.Row="0" BackgroundColor="#0072C6" Padding="20,15,20,30">

            <Label HorizontalOptions="Center" FontSize="14" Margin="0,5,0,15">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Your previous bill on " TextColor="#B3D4F0" />
                        <Span Text="Jun 31" TextColor="White" FontAttributes="Bold" />
                        <Span Text=" was " TextColor="#B3D4F0" />
                        <Span Text="$185.87" TextColor="White" FontAttributes="Bold" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <BoxView HeightRequest="1" Color="White" Opacity="0.2" Margin="30,0" />

            <Label Text="$198.82" 
                   FontSize="64" 
                   FontAttributes="Bold" 
                   TextColor="White" 
                   HorizontalOptions="Center" 
                   Margin="0,15,0,0" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,5,0,25">
                <Label Text="Balance due " TextColor="White" FontSize="14" VerticalOptions="Center" />
                <Label Text="August 19" TextColor="White" FontAttributes="Bold" FontSize="14" VerticalOptions="Center" />
                <Label Text="ⓘ" TextColor="White" FontSize="16" VerticalOptions="Center" Margin="5,0,0,0" />
            </HorizontalStackLayout>

            <Button Text="Pay Bill" 
                    BackgroundColor="White" 
                    TextColor="#0072C6" 
                    FontAttributes="Bold" 
                    FontSize="16"
                    HeightRequest="48"
                    CornerRadius="4"
                    Shadow="{x:Null}" />

        </VerticalStackLayout>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">

            <Border BackgroundColor="White" 
                    Margin="20,25,20,20" 
                    Padding="20" 
                    Stroke="Transparent"
                    StrokeThickness="0"
                    VerticalOptions="Fill">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.15" Offset="0,4" Radius="8" />
                </Border.Shadow>

                <VerticalStackLayout>

                    <Image Source="buildings_image.png" 
                           HeightRequest="100" 
                           WidthRequest="150" 
                           HorizontalOptions="Center" 
                           Margin="0,0,0,20" />

                    <Label Text="Your bill is $14.93 lower than your last bill." 
                           FontSize="20" 
                           FontAttributes="Bold" 
                           TextColor="Black" 
                           LineBreakMode="WordWrap"
                           Margin="0,0,0,10" />

                    <Label FontSize="15" TextColor="#4A4A4A" LineBreakMode="WordWrap">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Want to get the same bill every month? Enroll in our " />
                                <Span Text="Level Payment Plan." FontAttributes="Bold" TextColor="#1A1A1A" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                </VerticalStackLayout>
            </Border>
        </ScrollView>

    </Grid>
</ContentView>